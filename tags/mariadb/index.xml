&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">grant all privileges on *.* to gitea@&lt;span class="s2">&amp;#34;%&amp;#34;&lt;/span> identified by &lt;span class="s2">&amp;#34;123&amp;#34;&lt;/span> with grant option&lt;span class="p">;&lt;/span>

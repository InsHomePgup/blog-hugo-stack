&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">grant all privileges on *.* to root@&lt;span class="s2">&amp;#34;%&amp;#34;&lt;/span> identified by &lt;span class="s2">&amp;#34;pwd&amp;#34;&lt;/span> with grant option&lt;span class="p">;&lt;/span> flush privileges&lt;span class="p">;&lt;/span>

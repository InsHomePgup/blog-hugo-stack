&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">pnpm create vite &lt;span class="o">[&lt;/span>项目名称&lt;span class="o">]&lt;/span> --template react-ts
